# 1. Estágio de Compilação
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copia os arquivos do repositório para o container
COPY . .

# Restaura as dependências da API apontando para o caminho correto
RUN dotnet restore "backend/AgivysSystem.Api/AgivysSystem.Api.csproj"

# Compila o projeto em modo Release
RUN dotnet publish "backend/AgivysSystem.Api/AgivysSystem.Api.csproj" -c Release -o /app/publish /p:UseAppHost=false

# 2. Estágio de Execução
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app
EXPOSE 8080

# Copia apenas os binários compilados do estágio anterior
COPY --from=build /app/publish .

# Define o ponto de entrada da aplicação
ENTRYPOINT ["dotnet", "AgivysSystem.Api.dll"]